# docker build --rm -f clickhouse_dockerfile -t clickhousedb .

FROM clickhouse/clickhouse-server:24.8

RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      nano cron tini\
 && rm -rf /var/lib/apt/lists/*

COPY ./clickhouse_init.sql /docker-entrypoint-initdb.d/01_init.sql
